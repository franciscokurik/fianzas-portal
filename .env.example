# Variables de entorno del Portal de Fianzas (Vercel + Neon Postgres)
# Copia a .env para desarrollo local, o configúralas en Vercel (Project Settings → Environment Variables).

# Cadena de conexión de Postgres (Neon / Vercel Postgres). Usa la versión "pooled".
DATABASE_URL=postgresql://usuario:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Secreto para firmar los JWT de sesión (cadena larga y aleatoria).
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio

# Token de Vercel Blob (se inyecta solo al conectar un Blob Store en Vercel).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Clave para proteger el endpoint /api/setup (crear esquema + sembrar demo).
SETUP_KEY=una-clave-secreta-para-setup

# (Opcional) Envío de correos. Por defecto 'console' (solo imprime).
EMAIL_MODE=console
EMAIL_FROM=fianzas@fortex.mx
