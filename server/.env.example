# Copia este archivo a .env y ajusta los valores

# Puerto del servidor API
PORT=4000

# Secreto para firmar tokens JWT (cámbialo por algo largo y aleatorio en producción)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Origen permitido para CORS (el cliente React en desarrollo)
CLIENT_ORIGIN=http://localhost:5173

# --- Email (opcional para MVP) ---
# Si EMAIL_MODE=console, las alertas se imprimen en consola (no se envían).
# Para usar SendGrid: EMAIL_MODE=smtp y completa las credenciales SMTP de SendGrid.
EMAIL_MODE=console
EMAIL_FROM=fianzas@fortex.mx
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
