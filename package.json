{
  "name": "fianzas-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Portal de Fianzas Fortex — despliegue en Vercel (frontend estático + API serverless + Postgres)",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "npm --prefix client install --include=dev && npm --prefix client run build",
    "start": "node --no-warnings server/src/index.js",
    "seed": "node --no-warnings server/src/seed.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/blob": "^0.27.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15"
  }
}
